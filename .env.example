# Long random string. Used both for API bearer auth and the login cookie.
PCAST_TOKEN=replace-with-a-long-random-string

# HTTP port. Tailscale serve fronts this in production.
PORT=8080

# Path prefix to mount the backend under. Leave EMPTY for almost all setups,
# including Tailscale serve --set-path=/pod — Tailscale strips the prefix
# before forwarding, so the backend should listen at root. The PWA's HTML
# uses <base href="./"> and relative URLs, so the browser-side prefix is
# handled automatically.
#
# Only set this (e.g. BASE_PATH=/pod) if your reverse proxy preserves the
# path prefix on forwarded requests.
BASE_PATH=

# Where the SQLite DB and chapter artwork live.
DATA_DIR=./data

# Hourly RSS sync. Override for development.
SYNC_INTERVAL_MS=3600000

# Local library: drop *.xml feed files anywhere under this dir and they're
# imported automatically on each sync. file:// audio URLs in those feeds are
# allowed if they resolve INSIDE this directory (path-traversal protected).
# Default is ./data/library (auto-created). Set to "" to disable entirely.
# LOCAL_LIBRARY_DIR=./data/library

# Optional: turn on verbose logging.
# DEBUG=1
